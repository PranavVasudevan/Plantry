rules_version = '2';

// Plantry never talks to Firestore directly from the browser — the frontend
// only calls the backend API, and the backend uses the Firebase Admin SDK
// (which bypasses these rules entirely). This ruleset just makes sure that
// if anyone ever points a client SDK at this project directly, they get
// nothing, rather than relying on "nobody would do that" as the only line
// of defense.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
