# Port the Express server listens on
PORT=4000

# --- Firebase Admin credentials ---
# Pull these three values out of your Firebase service account JSON
# (Project Settings -> Service accounts -> Generate new private key).
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Keep the \n sequences literal — firebaseAdmin.js unescapes them at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:3000

# Optional — only needed if you flip USE_GEMINI to true in routes/parseItems.js
GEMINI_API_KEY=
